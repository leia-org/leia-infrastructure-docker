# LEIA Infrastructure Configuration
# Copy this file to .env and update the values as needed

# DATABASE CONFIGURATION
MONGO_USERNAME=admin
MONGO_PASSWORD=password123
MONGO_PORT_CATALOG=27017
MONGO_PORT_WORKBENCH=27018

# REDIS CONFIGURATION
REDIS_PORT=6379

# SERVICE PORTS
PORT_MANAGER=3001
PORT_WORKBENCH_BACK=3002
PORT_RUNNER=3003
PORT_WORKBENCH_FRONT_PUBLIC=3004
PORT_WORKBENCH_FRONT_PRIVATE=3005

# SERVICE URLS
MANAGER_URL=http://manager:80
WORKBENCH_BACK_URL=http://workbench-back:80
RUNNER_URL=http://runner:80
WORKBENCH_FRONT_PUBLIC_URL=http://workbench-front-public:3000
WORKBENCH_FRONT_PRIVATE_URL=http://workbench-front-private:3000

# FRONTEND URLS (for CORS and redirects)
FRONTEND_URL_PUBLIC=http://localhost:3004
FRONTEND_URL_PRIVATE=http://localhost:3005

# SECURITY CONFIGURATION
# Can put anything for these values for now (except OPEN AI key)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
API_KEY=your-api-key-change-this-in-production
RUNNER_KEY=your-runner-key-change-this-in-production
MANAGER_KEY=your-manager-key-change-this-in-production
ADMIN_SECRET=your-admin-secret-change-this-in-production

# DEFAULT ADMIN USER
DEFAULT_ADMIN_EMAIL=admin@leia.org
DEFAULT_ADMIN_PASSWORD=admin123

# ENVIRONMENT
NODE_ENV=production
